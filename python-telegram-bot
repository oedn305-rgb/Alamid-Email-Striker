import os
from telegram import Bot
from telegram.ext import Application, CommandHandler, MessageHandler, filters

# الحصول على BOT_TOKEN و CHAT_ID من GitHub Secrets أو متغيرات البيئة
TOKEN = os.getenv('BOT_TOKEN')  # استبدلها بالتوكن الخاص بك
CHAT_ID = os.getenv('CHAT_ID')  # استبدلها بـ chat_id الخاص بك

# وظيفة رد البوت عند إرسال أمر /start
async def start(update, context):
    await update.message.reply_text("مرحبًا! أنا بوت مستشار قانوني. كيف يمكنني مساعدتك؟")

# وظيفة رد البوت عند إرسال أي رسالة نصية
async def echo(update, context):
    await update.message.reply_text(f"أنت قلت: {update.message.text}")

# وظيفة لإرسال رسالة مجدولة
async def send_scheduled_message(context):
    await context.bot.send_message(chat_id=CHAT_ID, text="هذه رسالة مجدولة!")

# إعداد البوت وإضافة الوظائف
async def main():
    # استخدام Application بدلاً من Updater
    application = Application.builder().token(TOKEN).build()

    # إضافة الأوامر
    application.add_handler(CommandHandler("start", start))

    # إضافة MessageHandler للتفاعل مع أي رسالة نصية
    application.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, echo))

    # إرسال رسالة مجدولة كل 60 ثانية
    job_queue = application.job_queue
    job_queue.run_repeating(send_scheduled_message, interval=60, first=0)

    # بدء البوت
    await application.run_polling()

if __name__ == '__main__':
    import asyncio
    asyncio.run(main())
