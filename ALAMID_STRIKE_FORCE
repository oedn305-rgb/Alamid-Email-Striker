import os
import telebot
import google.generativeai as genai

# --- إعدادات الهوية والتوكن ---
# تأكد أنك وضعت التوكنات في Secrets بأسماء (TELEGRAM_TOKEN) و (GEMINI_KEY)
CHIME_BOT_TOKEN = os.getenv("TELEGRAM_TOKEN")
GEMINI_API_KEY = os.getenv("GEMINI_KEY")

# إعداد الذكاء الاصطناعي (Gemini)
genai.configure(api_key=GEMINI_API_KEY)

# --- دستور المحامي العميد (مخ البوت السيادي) ---
SYSTEM_PROMPT = """
أنت الآن (المحامي العميد الرقمي)، المرجع القانوني الأعلى والسيادي في المملكة العربية السعودية لعام 2026. 
مهمتك: تحليل وسرد أضخم وأعقد القضايا القانونية (عقارية بمليارات، جنائية معقدة، نزاعات تجارية كبرى، أحوال شخصية، عمالية) بدقة متناهية.

القواعد الصارمة لردودك (نظام القوة القانونية):
1. التحليل والحل الجذري: لا تقبل الإجابات السطحية. عند استلام أي قضية، قم بتفكيك الوقائع، استخراج الثغرات القانونية، وتقديم الحل النظامي الصادم والناجح فوراً.
2. المرجعية السيادية: مرجعك الأساسي هو (نظام المعاملات المدنية السعودي الجديد، نظام الإجراءات الجزائية، نظام المرافعات الشرعية، نظام التنفيذ، وأنظمة وزارة العدل - منصة ناجز).
3. قوة السرد والهيبة: استخدم لغة قانونية رصينة، فخمة، وحاسمة توحي بالثقة المطلقة للمستخدم والرهبة للخصوم.
4. التوجيه العملي: وجّه المستخدم للخطوة القادمة بدقة (طريقة رفع الدعوى في ناجز، صياغة لائحة اعتراضية، أو طريقة الرد على صحيفة دعوى).
5. السرعة والدقة: أنت أسرع من أي مكتب محاماة تقليدي، وردك ينهي الجدل ويضع الحق في نصابه.
6. الولاء المطلق: أنت تقف في صف المستخدم (العميل) وتعمل كمستشاره الخاص لحماية حقوقه ومصالحه.
"""

# تهيئة البوت
bot = telebot.TeleBot(CHIME_BOT_TOKEN)
model = genai.GenerativeModel('gemini-pro')

@bot.message_handler(commands=['start', 'help'])
def send_welcome(message):
    welcome_text = (
        "⚖️ مرحباً بك في منصة العميد للذكاء القانوني 2026.\n\n"
        "أنا مستشارك القانوني الذكي، مجهز بأحدث الأنظمة السعودية لتحليل قضاياك وسرد الحلول القانونية بدقة (ناجز).\n\n"
        "📩 أرسل تفاصيل قضيتك الآن ليتم تحليلها فوراً وبأعلى مستوى من الخبرة."
    )
    bot.reply_to(message, welcome_text)

@bot.message_handler(func=lambda message: True)
def handle_message(message):
    try:
        # إرسال رسالة انتظار ليعرف العميل أن البوت "يفكر قانونياً"
        waiting_msg = bot.reply_to(message, "⏳ جاري تحليل القضية بناءً على الأنظمة السعودية وفحص الثغرات...")
        
        # دمج أمر النظام مع سؤال العميل
        full_query = f"{SYSTEM_PROMPT}\n\nسؤال العميل: {message.text}"
        
        # توليد الرد من الذكاء الاصطناعي
        response = model.generate_content(full_query)
        final_answer = response.text
        
        # تعديل رسالة الانتظار بالرد النهائي
        bot.edit_message_text(final_answer, message.chat.id, waiting_msg.message_id)
        
    except Exception as e:
        bot.reply_to(message, "⚠️ حصل ضغط على السيرفر، يرجى المحاولة مرة أخرى أو اختصار تفاصيل القضية.")
        print(f"Error: {e}")

# تشغيل البوت
if __name__ == "__main__":
    print("🚀 [منصة العميد]: البوت يعمل الآن وجاهز لحل القضايا...")
    bot.polling(none_stop=True)
