import os, telebot, smtplib
from email.message import EmailMessage

# السحب من السيكرتس
TOKEN = os.getenv("MS_APP_PASS")
MY_EMAIL = os.getenv("GMAIL_USER")
MY_PASS = os.getenv("GMAIL_PASS")

def auto_strike():
    print("🎯 جاري استهداف أول 50 عميل من الـ 1158...")
    try:
        with open("emails.txt", "r") as f:
            targets = [l.strip() for l in f.readlines() if "@" in l]
        
        count = 0
        with smtplib.SMTP_SSL('smtp.gmail.com', 465) as smtp:
            smtp.login(MY_EMAIL, MY_PASS)
            for target in targets[:50]:
                msg = EmailMessage()
                msg.set_content("⚖️ مكتب العميد للاستشارات القانونية 2026\nخدمتكم شرف لنا.")
                msg['Subject'] = "تواصل قانوني عاجل"
                msg['From'] = MY_EMAIL
                msg['To'] = target
                smtp.send_message(msg)
                count += 1
        print(f"✅ تم إرسال {count} إيميل بنجاح!")
        return count
    except Exception as e:
        print(f"❌ خطأ: {e}")
        return 0

if __name__ == "__main__":
    # يرسل فوراً أول ما يشتغل السيستم
    sent_count = auto_strike()
    
    # ثم يشغل البوت للرد على استفساراتك
    bot = telebot.TeleBot(TOKEN)
    bot.remove_webhook()
    
    print("🚀 البوت متصل الآن لمراقبة الردود...")
    @bot.message_handler(commands=['start', 'status'])
    def status(message):
        bot.reply_to(message, f"⚖️ النظام شغال! آخر حملة أرسلت {sent_count} رسالة للعملاء.")
    
    bot.infinity_polling()
