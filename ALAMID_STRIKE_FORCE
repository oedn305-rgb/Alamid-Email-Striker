# 2. وظيفة إرسال الإيميلات (تعمل في الخلفية)
def send_mass_emails():
    print("🚀 بدء إرسال الإيميلات...")
    try:
        if os.path.exists("emails.txt"):
            with open("emails.txt", "r", encoding="utf-8") as f:
                targets = [l.strip() for l in f if "@" in l]
            
            if targets:
                server = smtplib.SMTP_SSL('smtp.gmail.com', 465)
                server.login(MY_EMAIL, MY_PASS)
                
                count = 0
                for target in targets[:100]: # دفعة أولى 100
                    try:
                        subject = "⚖️ استشارة قانونية - مكتب المستشار السعودي"
                        body = "للاستشارة الفورية، تواصل معنا عبر البوت:\nhttps://t.me/SaudiLegal_AI_bot"
                        msg = f"From: {MY_EMAIL}\nTo: {target}\nSubject: {subject}\n\n{body}"
                        server.sendmail(MY_EMAIL, target, msg.encode('utf-8'))
                        count += 1
                    except: continue
                server.quit()
                print(f"✅ تم إرسال {count} إيميل بنجاح.")
                bot.send_message(CHAT_ID, f"⚖️ *تقرير العميد*\n\n✅ تم إرسال `{count}` إيميل بنجاح.\n🚀 البوت الآن في وضع الاستقبال.")
    except Exception as e:
        print(f"❌ خطأ في الإيميلات: {e}")

if __name__ == "__main__":
    # تشغيل الإيميلات في مسار منفصل عشان ما يعلق البوت
    email_thread = threading.Thread(target=send_mass_emails)
