import os, smtplib, requests

# --- بياناتك المباشرة هنا (أدخلها بدقة) ---
MY_EMAIL = "oedn305@gmail.com"  # إيميلك
MY_PASS = "xxxx xxxx xxxx xxxx"    # كود الـ 16 حرف (App Password) من قوقل
TOKEN = "xxxxxxxxxx:xxxxxxxxxxxxxxxxxxxxxxxxxxx"  # توكن البوت حقك
CHAT_ID = "6381014522"             # آيدي حسابك في تليجرام
# ---------------------------------------

def start_strike():
    print(f"🚀 [نظام العميد 2026]: بدء الهجوم المباشر بالإيميل: {MY_EMAIL}")
    
    try:
        # التأكد من وجود ملف الأهداف
        if not os.path.exists("emails.txt"):
            return "❌ خطأ: ملف emails.txt غير موجود!"
            
        with open("emails.txt", "r", encoding="utf-8") as f:
            targets = [line.strip() for line in f if "@" in line]
        
        if not targets:
            return "❌ ملف الأهداف فارغ!"

        # الاتصال المباشر بسيرفر قوقل
        server = smtplib.SMTP_SSL('smtp.gmail.com', 465)
        server.login(MY_EMAIL, MY_PASS)
        
        count = 0
        # إرسال لأول 100 هدف في كل تشغيلة (عشان قوقل ما يحظرك)
        for target in targets[:100]: 
            try:
                # صياغة الرسالة يدوياً (Raw) لضمان العمل 100%
                subject = "استشارة قانونية - مكتب العميد"
                body = "مكتب العميد يرحب بكم ويسعد بخدمتكم في عام 2026."
                
                raw_msg = f"From: {MY_EMAIL}\nTo: {target}\nSubject: {subject}\n\n{body}"
                
                server.sendmail(MY_EMAIL, target, raw_msg.encode('utf-8'))
                count += 1
                print(f"✅ [{count}] تم الإرسال بنجاح إلى: {target}")
            except Exception as e:
                print(f"⚠️ تخطي {target}: {e}")
                continue
            
        server.quit()
        return f"✅ نجاح: تم استهداف {count} عميل بنجاح!"
        
    except Exception as e:
        return f"❌ فشل النظام: {str(e)}"

if __name__ == "__main__":
    # تشغيل المنظومة
    report = start_strike()
    print(report)
    
    # إرسال التقرير النهائي لجوالك مباشرة
    try:
        url = f"https://api.telegram.org/bot{TOKEN}/sendMessage"
        requests.post(url, json={"chat_id": CHAT_ID, "text": f"⚖️ تقرير العميد 2026:\n{report}"})
    except:
        pass
