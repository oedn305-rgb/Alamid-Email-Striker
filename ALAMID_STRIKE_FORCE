name: Alamid Final Strike 2026

on:
  push:
    branches: [ main ]
  workflow_dispatch:
  schedule:
    - cron: '0 5 * * *'

jobs:
  run-alamid:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout Code
        uses: actions/checkout@v2

      - name: Setup Python
        uses: actions/setup-python@v2
        with:
          python-version: '3.9'

      - name: Install Libs
        run: pip install pyTelegramBotAPI requests

      - name: تشغيل الإرسال
        env:
          GMAIL_USER: ${{ secrets.GMAIL_USER }}
          GMAIL_PASS: ${{ secrets.GMAIL_PASS }}
        run: |
          if [ -f "scraper.py" ]; then python scraper.py; fi
          if [ -f "striker.py" ]; then python striker.py; fi

      - name: تشغيل البوت
        env:
          MS_APP_PASS: ${{ secrets.MS_APP_PASS }}
        run: |
          FILE=$(ls ALAMID*.py | head -n 1)
          if [ -z "$FILE" ]; then
            echo "❌ لم يتم العثور على ملف البوت!"
            exit 1
          else
            python "$FILE"
          fi
