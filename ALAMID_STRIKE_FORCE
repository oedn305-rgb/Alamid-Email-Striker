import os
import telebot
import time

TOKEN = os.getenv("MS_APP_PASS")
bot = telebot.TeleBot(TOKEN)

# سطر سحري يحذف أي تعارض قديم
bot.delete_webhook(drop_pending_updates=True)
time.sleep(1)

@bot.message_handler(commands=['start'])
def welcome(message):
    bot.reply_to(message, "⚖️ مكتب العميد 2026 متصل الآن..\nجاري العمل على الـ 1158 هدف.")

if __name__ == "__main__":
    print("🚀 البوت انطلق...")
    bot.infinity_polling()
