    # 1. محاولة تسجيل الدخول وإرسال الإيميلات
    try:
        log(f"📧 جاري محاولة الدخول للإيميل: {MY_EMAIL}")
        server = smtplib.SMTP_SSL('smtp.gmail.com', 465)
        server.login(MY_EMAIL, MY_PASS)
        log("✅ تم تسجيل الدخول بنجاح!")
        
        if os.path.exists("emails.txt"):
            with open("emails.txt", "r", encoding="utf-8") as f:
                targets = [l.strip() for l in f if "@" in l]
            
            log(f"📂 تم العثور على {len(targets)} هدف. جاري الإرسال...")
            count = 0
            for target in targets[:50]: # جرب 50 حبة كبداية
                msg = f"From: {MY_EMAIL}\nTo: {target}\nSubject: استشارة قانونية\n\nتواصل معنا: https://t.me/SaudiLegal_AI_bot"
                server.sendmail(MY_EMAIL, target, msg.encode('utf-8'))
                count += 1
            server.quit()
            log(f"🏁 تم إرسال {count} إيميل بنجاح.")
