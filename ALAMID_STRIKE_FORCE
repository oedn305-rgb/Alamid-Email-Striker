import os, smtplib, telebot, sys
from email.mime.text import MIMEText
from email.header import Header

# --- البيانات ---
TOKEN = "8717546599:AAHgnXRdPwoz1mV85LZft962ZU19xXnHBks"
MY_EMAIL = "oedn305@gmail.com"
CHAT_ID = "6381014522"

raw_pass = str(os.getenv("GMAIL_PASS", "")).strip()
MY_PASS = "".join(filter(lambda x: x.isascii() and not x.isspace(), raw_pass))

def log(text):
    print(text)
    sys.stdout.flush()

bot = telebot.TeleBot(TOKEN)

def start_alamid():
    log("🚀 [نظام العميد]: بدء عملية الإرسال المباشر...")
    sent_count = 0
    
    # 1. قراءة الملف
    if not os.path.exists("emails.txt"):
        log("❌ خطأ: ملف emails.txt غير موجود!")
        return

    with open("emails.txt", "r", encoding="utf-8") as f:
        targets = [l.strip() for l in f if "@" in l]
    
    log(f"📂 تم تحميل {len(targets)} هدف. جاري الاتصال بقوقل...")

    try:
        # 2. فتح الاتصال مع قوقل
        server = smtplib.SMTP_SSL('smtp.gmail.com', 465)
        server.login(MY_EMAIL, MY_PASS)
        log("✅ تم الاتصال بنجاح. جاري الإرسال الآن...")

        for target in targets:
            try:
                subject = "⚖️ استشارة قانونية عاجلة - مكتب المستشار السعودي"
                body = "مرحباً، للاستشارة القانونية الفورية تواصل معنا عبر البوت:\nhttps://t.me/SaudiLegal_AI_bot"
                
                msg = MIMEText(body, 'plain', 'utf-8')
                msg['Subject'] = Header(subject, 'utf-8')
                msg['From'] = MY_EMAIL
                msg['To'] = target
                
                server.sendmail(MY_EMAIL, [target], msg.as_string())
                sent_count += 1
                
                # طباعة فورية لكل إيميل يتم إرساله
                log(f"📤 [{sent_count}] تم الإرسال إلى: {target}")
                
                # إشعار كل 50 إيميل في تليجرام
                if sent_count % 50 == 0:
                    bot.send_message(CHAT_ID, f"✅ تم إرسال {sent_count} إيميل حتى الآن...")
                    
            except Exception as e:
                log(f"⚠️ فشل الإرسال لـ {target}: {e}")
                continue
        
        server.quit()
        log(f"🏁 العملية انتهت. إجمالي المرسل: {sent_count}")
        bot.send_message(CHAT_ID, f"⚖️ تمت المهمة بنجاح!\nتم إرسال {sent_count} إيميل للعملاء.")

    except Exception as e:
        log(f"❌ فشل النظام: {e}")

    # 3. تشغيل البوت للاستقبال
    log("⚖️ البوت الآن في وضع الاستقبال...")
    bot.infinity_polling()

if __name__ == "__main__":
    start_alamid()
