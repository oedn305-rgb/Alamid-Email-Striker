import os
import telebot
import time
import requests

# 1. إعدادات النظام
TOKEN = os.getenv("MS_APP_PASS")

def start_bot():
    try:
        # حذف الـ Webhook يدويًا قبل البدء (حل جذري للتعارض)
        requests.get(f"https://api.telegram.org/bot{TOKEN}/deleteWebhook?drop_pending_updates=True")
        time.sleep(2)
        
        bot = telebot.TeleBot(TOKEN)
        
        @bot.message_handler(commands=['start'])
        def welcome(message):
            bot.reply_to(message, "⚖️ نظام العميد 2026 متصل الآن!\nجاري معالجة الـ 1158 هدف.")

        print("🚀 [العميد]: البوت انطلق الآن بنجاح...")
        bot.infinity_polling(timeout=20, long_polling_timeout=10)
        
    except Exception as e:
        print(f"⚠️ حدث خطأ: {e}")
        print("🔄 جاري إعادة المحاولة خلال 5 ثوانٍ...")
        time.sleep(5)
        start_bot()

if __name__ == "__main__":
    if not TOKEN:
        print("❌ خطأ: التوكن (MS_APP_PASS) غير موجود في السيكرتس!")
    else:
        start_bot()
