def start_alamid():
    log("🚀 [نظام العميد]: بدء العملية الكبرى...")
    
    # 1. مرحلة قراءة الملفات وإرسال الإيميلات
    sent_count = 0
    try:
        # نبحث عن أي ملف نصي يحتوي على إيميلات في المجلد
        targets = []
        files_to_check = ["emails.txt", "Emails.txt", "list.txt"]
        
        for f_name in files_to_check:
            if os.path.exists(f_name):
                log(f"📂 تم العثور على ملف: {f_name}")
                with open(f_name, "r", encoding="utf-8") as f:
                    targets.extend([l.strip() for l in f if "@" in l])
                break # نكتفي بأول ملف نلقاه

        if targets:
            log(f"📧 جاري محاولة إرسال لـ {len(targets)} هدف...")
            server = smtplib.SMTP_SSL('smtp.gmail.com', 465)
            server.login(MY_EMAIL, MY_PASS)
            log("✅ تم الاتصال بسيرفر قوقل بنجاح!")

            for target in targets:
                try:
                    subject = "⚖️ استشارة قانونية - مكتب المستشار السعودي"
                    body = "للاستشارة الفورية وعرض قضيتكم، تفضلوا بزيارة البوت الرسمي:\nhttps://t.me/SaudiLegal_AI_bot"
                    
                    msg = MIMEText(body, 'plain', 'utf-8')
                    msg['Subject'] = Header(subject, 'utf-8')
                    msg['From'] = MY_EMAIL
                    msg['To'] = target
                    
                    server.sendmail(MY_EMAIL, [target], msg.as_string())
                    sent_count += 1
                    if sent_count % 10 == 0: log(f"📤 تم إرسال {sent_count}...")
                except: continue
            
            server.quit()
            log(f"🏁 تم الانتهاء! إجمالي الإيميلات المرسلة: {sent_count}")
            try: bot.send_message(CHAT_ID, f"✅ تم بنجاح إرسال `{sent_count}` إيميل للعملاء.")
            except: pass
        else:
            log("⚠️ لم يتم العثور على أي ملف إيميلات (تأكد من وجود emails.txt)")

    except Exception as e:
        log(f"❌ حدث خطأ فني: {e}")

    # 2. تشغيل البوت للاستقبال
    log("⚖️ البوت الآن مستعد للرد الفوري على القضايا...")
    bot.infinity_polling(timeout=15)

if __name__ == "__main__":
    start_alamid()
