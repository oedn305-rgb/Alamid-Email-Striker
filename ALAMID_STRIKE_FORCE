import os, smtplib, requests

# 1. سحب البيانات من السيكرتس (تأكد أن الأسماء مطابقة لما في GitHub)
TOKEN = str(os.getenv("MS_APP_PASS", "")).strip()  # توكن البوت
MY_EMAIL = "oedn305@gmail.com"                    # إيميلك ثابت
MY_PASS = str(os.getenv("GMAIL_PASS", "")).strip() # كود الـ 16 حرف اللي سويته قبل 50 دقيقة
CHAT_ID = "6381014522"                            # آيدي تليجرام الخاص بك

def final_strike():
    print(f"🚀 [نظام العميد 2026]: بدء الهجوم باستخدام: {MY_EMAIL}")
    
    # فحص أمان للسيكرتس
    if not MY_PASS:
        return "❌ خطأ: السيكرت GMAIL_PASS فاضي في إعدادات GitHub!"
    
    try:
        # قراءة الأهداف من الملف
        if not os.path.exists("emails.txt"):
            return "❌ خطأ: ملف emails.txt غير موجود!"
            
        with open("emails.txt", "r", encoding="utf-8") as f:
            targets = [line.strip() for line in f if "@" in line]
        
        if not targets:
            return "❌ ملف الأهداف فارغ!"

        # الاتصال المباشر بسيرفر قوقل (الأقوى)
        server = smtplib.SMTP_SSL('smtp.gmail.com', 465)
        server.login(MY_EMAIL, MY_PASS)
        
        count = 0
        for target in targets[:100]: 
            try:
                # صياغة الرسالة "خام" لكسر أي خطأ في البيانات
                subject = "استشارة قانونية - مكتب العميد"
                body = "مكتب العميد يرحب بكم ويسعد بخدمتكم."
                
                raw_msg = f"From: {MY_EMAIL}\nTo: {target}\nSubject: {subject}\n\n{body}"
                
                server.sendmail(MY_EMAIL, target, raw_msg.encode('utf-8'))
                count += 1
                print(f"✅ [{count}] تم الإرسال إلى: {target}")
            except:
                continue
            
        server.quit()
        return f"✅ نجاح باهر: تم استهداف {count} عميل بنجاح!"
        
    except Exception as e:
        return f"❌ فشل الدخول (535): تأكد من كود الـ 16 حرف في GMAIL_PASS\n{str(e)}"

if __name__ == "__main__":
    # تشغيل النظام
    result = final_strike()
    print(result)
    
    # إرسال التقرير النهائي لجوالك
    try:
        url = f"https://api.telegram.org/bot{TOKEN}/sendMessage"
        requests.post(url, json={"chat_id": CHAT_ID, "text": f"⚖️ تقرير العميد:\n{result}"})
    except:
        pass
