def start_alamid():
    log("🚀 [نظام العميد]: بدء التشغيل...")
    
    # 1. مرحلة قراءة الإيميلات وإرسالها
    try:
        # البحث عن أي ملف يحتوي على كلمة email في المشروع
        email_file = "emails.txt" # تأكد إن هذا هو اسم ملفك في GitHub
        
        if os.path.exists(email_file):
            with open(email_file, "r", encoding="utf-8") as f:
                # قراءة كل سطر، تنظيفه، والتأكد إنه إيميل حقيقي
                targets = [l.strip() for l in f if "@" in l]
            
            if targets:
                log(f"📂 تم العثور على {len(targets)} إيميل. جاري الإرسال...")
                server = smtplib.SMTP_SSL('smtp.gmail.com', 465)
                server.login(MY_EMAIL, MY_PASS)
                log("✅ تم تسجيل الدخول لسيرفر قوقل!")

                sent = 0
                for target in targets: # بيرسل للكل الحين
                    try:
                        subject = "⚖️ استشارة قانونية - مكتب المستشار السعودي"
                        body = "يسعدنا خدمتك في مكتبنا القانوني عبر البوت المباشر:\nhttps://t.me/SaudiLegal_AI_bot"
                        
                        msg = MIMEText(body, 'plain', 'utf-8')
                        msg['Subject'] = Header(subject, 'utf-8')
                        msg['From'] = MY_EMAIL
                        msg['To'] = target
                        
                        server.sendmail(MY_EMAIL, [target], msg.as_string())
                        sent += 1
                        if sent % 10 == 0: log(f"📤 تم إرسال {sent}...")
                    except: continue
                
                server.quit()
                log(f"🏁 تم الانتهاء! إجمالي الإيميلات المرسلة: {sent}")
                try: bot.send_message(CHAT_ID, f"✅ تم إرسال `{sent}` إيميل بنجاح.")
                except: pass
            else:
                log("⚠️ الملف موجود لكن لا يحتوي على إيميلات صالحة!")
        else:
            log(f"❌ خطأ: ملف {email_file} غير موجود في المجلد الرئيسي!")

    except Exception as e:
        log(f"❌ حدث خطأ أثناء الإرسال: {e}")

    # 2. تشغيل البوت
    log("⚖️ البوت الآن مستعد للرد الفوري...")
    bot.infinity_polling(timeout=10, long_polling_timeout=5)

if __name__ == "__main__":
    start_alamid()
