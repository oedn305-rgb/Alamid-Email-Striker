    sent_count = 0
    
    try:
        # 1. إعداد الإيميل بطريقة تدعم اللغة العربية
        log("📧 جاري تسجيل الدخول...")
        server = smtplib.SMTP_SSL('smtp.gmail.com', 465)
        server.login(MY_EMAIL, MY_PASS)
        log("✅ دخلنا الإيميل بنجاح!")

        if os.path.exists("emails.txt"):
            with open("emails.txt", "r", encoding="utf-8") as f:
                targets = [l.strip() for l in f if "@" in l]
            
            log(f"📂 لقينا {len(targets)} هدف. جاري الإرسال...")
            
            for target in targets[:50]:
                try:
                    subject = "⚖️ مكتب المستشار القانوني السعودي"
                    body = "مرحباً، للاستشارة الفورية تواصل معنا: https://t.me/SaudiLegal_AI_bot"
                    
                    # تنسيق الرسالة ليدعم العربي 100%
                    msg = MIMEText(body, 'plain', 'utf-8')
                    msg['Subject'] = Header(subject, 'utf-8')
                    msg['From'] = MY_EMAIL
                    msg['To'] = target
                    
                    server.sendmail(MY_EMAIL, [target], msg.as_string())
