import os, smtplib, telebot, sys, time

# --- البيانات ---
TOKEN = "8717546599:AAHgnXRdPwoz1mV85LZft962ZU19xXnHBks"
MY_EMAIL = "oedn305@gmail.com"
CHAT_ID = "6381014522"

raw_pass = str(os.getenv("GMAIL_PASS", "")).strip()
MY_PASS = "".join(filter(lambda x: x.isascii() and not x.isspace(), raw_pass))

def log(text):
    print(text)
    sys.stdout.flush()

bot = telebot.TeleBot(TOKEN)

def start_alamid_batch():
    log("⚖️ [نظام العميد]: بدء إرسال الدفعة الآمنة (20 إيميل)...")
    
    if not os.path.exists("emails.txt"):
        log("❌ ملف الإيميلات غير موجود.")
        return

    with open("emails.txt", "r", encoding="utf-8") as f:
        targets = [l.strip() for l in f if "@" in l]
    
    # سنركز فقط على أول 20 إيميل في القائمة
    batch_targets = targets[:20]
    log(f"📂 تم تحديد أول {len(batch_targets)} هدف للإرسال اليوم.")

    try:
        server = smtplib.SMTP_SSL('smtp.gmail.com', 465)
        server.login(MY_EMAIL, MY_PASS)
        
        sent_count = 0
        for target in batch_targets:
            try:
                subject = "⚖️ استشارة قانونية - مكتب المستشار السعودي"
                body = "مرحباً بك، نسعد بخدمتك قانونياً عبر بوت تليجرام المباشر:\nhttps://t.me/SaudiLegal_AI_bot"
                
                msg = f"From: {MY_EMAIL}\nTo: {target}\nSubject: {subject}\n\n{body}"
                
                server.sendmail(MY_EMAIL, [target], msg.encode('utf-8'))
                sent_count += 1
                log(f"✅ [{sent_count}/20] تم الإرسال بنجاح إلى: {target}")

                # انتظار دقيقة كاملة بين كل إيميل وإيميل (نظامي جداً)
                if sent_count < 20:
                    log("⏳ انتظار 60 ثانية قبل الإيميل التالي...")
                    time.sleep(60)

            except Exception as e:
                log(f"⚠️ خطأ مع {target}: {e}")
                continue
        
        server.quit()
        log(f"🏁 تمت المهمة اليوم! تم إرسال {sent_count} رسالة بنجاح.")
        bot.send_message(CHAT_ID, f"⚖️ *تقرير الدفعة اليومية*\n✅ تم إرسال `{sent_count}` إيميل بنجاح وبشكل نظامي.")
        
    except Exception as e:
        log(f"❌ تعطل النظام: {e}")

    # تشغيل البوت لاستقبال القضايا
    log("⚖️ البوت الآن مستعد لاستقبال القضايا...")
    bot.infinity_polling()

if __name__ == "__main__":
    start_alamid_batch()
