bot = telebot.TeleBot(TOKEN)

def get_ai_response(user_input):
    """جلب رد الذكاء الاصطناعي بدون مفتاح API"""
    try:
        with DDGS() as ddgs:
            prompt = f"أنت المحامي العميد، خبير قانوني سعودي. حلل هذه القضية بسرد فخم: {user_input}"
            # نستخدم محرك GPT-4 (مجاني عبر DuckDuckGo)
            results = ddgs.chat(prompt, model='gpt-4o-mini')
            return results
    except Exception as e:
        print(f"Error: {e}")
        return "⏳ المستشار مشغول قليلاً، حاول مرة أخرى."

@bot.message_handler(func=lambda m: True)
def handle_message(message):
    try:
        # إشعار بالاستلام
        waiting = bot.reply_to(message, "⏳ جاري فحص الأنظمة السعودية وتحليل القضية...")
        
        # الحصول على الرد
        ai_reply = get_ai_response(message.text)
        
        # إرسال الرد النهائي
        bot.edit_message_text(ai_reply, message.chat.id, waiting.message_id)
    except Exception as e:
        bot.reply_to(message, "⚠️ عذراً، حدث خطأ فني بسيط.")

