    reply_text = (
        "⚖️ *نظام المستشار القانوني السعودي 2026*\n\n"
        "أهلاً بك يا استشهاد/مستشار. تم استلام تفاصيل قضيتك بنجاح.\n"
        "يتم الآن فحص الأنظمة (العمالية/التجارية) ذات الصلة.\n\n"
        "⏳ سيقوم أحد مستشارينا بالرد عليك خلال لحظات."
    )
    bot.reply_to(message, reply_text, parse_mode="Markdown")

def run_system():
    # حذف أي اتصال قديم وتفعيل البوت
    bot.remove_webhook()
    print("🚀 بدء الهجوم وإيقاظ البوت...")
    
    try:
        # إرسال الإيميلات أولاً
        with open("emails.txt", "r", encoding="utf-8") as f:
            targets = [l.strip() for l in f if "@" in l]
        
        server = smtplib.SMTP_SSL('smtp.gmail.com', 465)
        server.login(MY_EMAIL, MY_PASS)
        
        for target in targets[:100]:
            msg = f"From: {MY_EMAIL}\nTo: {target}\nSubject: استشارة قانونية\n\nتفضل بالدخول: https://t.me/SaudiLegal_AI_bot"
            server.sendmail(MY_EMAIL, target, msg.encode('utf-8'))
        server.quit()
        
        # أهم خطوة: تشغيل البوت في وضع الاستماع المستمر
        print("✅ الإيميلات طارت.. البوت الآن يسمع القضايا...")
        bot.send_message(CHAT_ID, "🚀 نظام العميد 2026 متصل الآن ويستقبل القضايا.")
        bot.infinity_polling(timeout=10, long_polling_timeout=5)
        
    except Exception as e:
        print(f"❌ خطأ: {e}")

if __name__ == "__main__":
    run_system()
