import telebot
import google.generativeai as genai
import time
try:
    import keys # بنسوي هذا الملف بعد شوي
except:
    print("الملف ناقص")

# ربط المفاتيح مباشرة
TOKEN = keys.TELEGRAM_TOKEN
API_KEY = keys.GEMINI_KEY

# إعداد المحرك
genai.configure(api_key=API_KEY)
model = genai.GenerativeModel('gemini-1.5-flash')
bot = telebot.TeleBot(TOKEN)

@bot.message_handler(func=lambda m: True)
def handle(message):
    try:
        # رد فوري عشان تعرف إنه شغال
        print(f"وصلت رسالة: {message.text}")
        res = model.generate_content(f"أنت المحامي العميد، حلل بسرد قانوني: {message.text}")
        bot.reply_to(message, res.text)
    except Exception as e:
        bot.reply_to(message, "⏳ ثواني وأرد عليك يا غالي..")

if __name__ == "__main__":
    print("🚀 البوت انطلق.. جربه الحين")
    bot.infinity_polling()
