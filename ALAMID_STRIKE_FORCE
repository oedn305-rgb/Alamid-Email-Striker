    @bot.message_handler(func=lambda message: True)
    def reply(message):
        log(f"📥 استلمت رسالة من {message.from_user.first_name}")
        bot.reply_to(message, "⚖️ تم استلام قضيتك بنجاح لدى مكتب المستشار السعودي.")

    try:
        bot.send_message(CHAT_ID, "🚀 النظام جاهز ويستقبل القضايا!")
        bot.polling(non_stop=True, timeout=20)
    except Exception as e:
        log(f"❌ البوت واجه مشكلة: {e}")

if __name__ == "__main__":
    start_process()
