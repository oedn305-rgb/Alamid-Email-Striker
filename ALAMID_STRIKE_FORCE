def send_legal_strike():
    print(f"⚖️ [نظام المستشار القانوني السعودي]: بدء استهداف الـ 1158 هدف...")
    
    try:
        if not os.path.exists("emails.txt"):
            print("❌ ملف emails.txt مفقود!")
            return 0
            
        with open("emails.txt", "r", encoding="utf-8") as f:
            targets = [line.strip() for line in f if "@" in line]
        
        if not targets:
            return 0

        server = smtplib.SMTP_SSL('smtp.gmail.com', 465)
        server.login(MY_EMAIL, MY_PASS)
        
        count = 0
        # إرسال دفعة من 100 هدف
        for target in targets[:100]: 
            try:
                # --- نص الرسالة القانوني المطور مع رابط البوت ---
                subject = "⚖️ استشارة قانونية فورية - مكتب المستشار القانوني السعودي"
                
                # رابط البوت المباشر
                bot_link = "https://t.me/SaudiLegal_AI_bot"
                
                body = f"""
تحية طيبة وبعد،،

يسعدنا في "مكتب المستشار القانوني السعودي 2026" إفادتكم بجاهزيتنا الكاملة لتقديم الاستشارات القانونية والتمثيل القضائي بكفاءة واحترافية عالية.

🎯 للحصول على استشارة فورية أو التحدث مع المستشار الذكي، تفضل بزيارة منصتنا الرسمية عبر الرابط التالي:
{bot_link}

لماذا نحن؟
- سرعة الرد والدقة القانونية.
- حلول مبتكرة لكافة القضايا (تجارية، عمالية، أحوال شخصية).
- خصوصية تامة لكافة البيانات.

نحن هنا لحماية حقوقكم وتعزيز موقفكم القانوني.

مع تحيات،
إدارة التواصل - مكتب المستشار القانوني السعودي 🇸🇦
                """
                
                msg = f"From: {MY_EMAIL}\nTo: {target}\nSubject: {subject}\nContent-Type: text/plain; charset=utf-8\n\n{body}"
                
                server.sendmail(MY_EMAIL, target, msg.encode('utf-8'))
                count += 1
                print(f"✅ تم الإرسال إلى: {target}")
            except Exception as e:
                print(f"⚠️ خطأ في هدف محدد: {e}")
                continue
            
        server.quit()
        return count
    except Exception as e:
        print(f"❌ فشل النظام: {e}")
        return 0

def send_telegram_report(count):
    # إرسال التقرير من البوت إلى حسابك الشخصي
    url = f"https://api.telegram.org/bot{TOKEN}/sendMessage"
    text = (
        f"⚖️ *تحديث نظام المستشار القانوني السعودي*\n\n"
        f"✅ تم إرسال الدفعة بنجاح لـ: `{count}` عميل.\n"
        f"🔗 الرابط المرسل: [SaudiLegal_AI_bot](https://t.me/SaudiLegal_AI_bot)\n"
        f"📊 المتبقي في القائمة: `{1158 - count}`\n\n"
        f"🚀 النظام الآن في وضع الانتظار."
    )
    payload = {
        "chat_id": CHAT_ID, 
        "text": text, 
        "parse_mode": "Markdown",
        "disable_web_page_preview": False
    }
    requests.post(url, json=payload)

