import os
import telebot
import google.generativeai as genai
import time

# سحب المفاتيح من السيكرتس اللي عندك (خلك على أساميك)
TOKEN = os.getenv("MS_APP_PASS")        # توكن تليجرام
API_KEY = os.getenv("ALAMID_API_KEY")  # مفتاح قوقل

# إعداد المحرك (Gemini 1.5 Flash) - الأسرع والأكثر تحملاً للضغط
genai.configure(api_key=API_KEY)
model = genai.GenerativeModel('gemini-1.5-flash')

bot = telebot.TeleBot(TOKEN)

# دستور العميد القانوني ⚖️
SYSTEM_PROMPT = """
أنت (المحامي العميد)، مستشار قانوني سعودي خبير.
ردودك يجب أن تكون: سردية، مفصلة، مدعمة بالأنظمة السعودية (مثل نظام المعاملات المدنية).
إذا سألك العميل، حلل القضية كأنك في قاعة محكمة.
"""

@bot.message_handler(func=lambda m: True)
def handle_message(message):
    try:
        # رسالة هيبة فورية
        waiting = bot.reply_to(message, "⏳ جاري استحضار النصوص النظامية وتحليل القضية...")
        
        # طلب الرد
        response = model.generate_content(f"{SYSTEM_PROMPT}\n\nالسؤال: {message.text}")
        
        # تعديل الرد وإرساله
        bot.edit_message_text(response.text, message.chat.id, waiting.message_id)
        
    except Exception as e:
        print(f"🔄 محاولة إنعاش البوت: {e}")
        time.sleep(2) # راحة بسيطة قبل إعادة المحاولة

# --- نظام "القلب النابض" (التشغيل الأبدي) ---
if __name__ == "__main__":
    print("🚀 [منصة العميد]: النظام بدأ.. لن يتوقف بإذن الله.")
    while True:
        try:
            bot.polling(none_stop=True, interval=1, timeout=60)
        except Exception as e:
            print(f"⚠️ حدث انقطاع، إعادة تشغيل تلقائية خلال 5 ثوانٍ... {e}")
            time.sleep(5)
