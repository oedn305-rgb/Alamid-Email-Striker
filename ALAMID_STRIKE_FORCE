def start_alamid():
    log("🚀 [نظام العميد]: بدء التشغيل...")
    
    # 1. إرسال الإيميلات
    if MY_PASS:
        try:
            log(f"📧 محاولة الدخول للإيميل باستخدام السيكرت...")
            server = smtplib.SMTP_SSL('smtp.gmail.com', 465)
            server.login(MY_EMAIL, MY_PASS)
            log("✅ تم تسجيل الدخول بنجاح!")

            if os.path.exists("emails.txt"):
                with open("emails.txt", "r", encoding="utf-8") as f:
                    targets = [l.strip() for l in f if "@" in l]
                
                sent = 0
                for target in targets[:100]:
                    try:
                        msg = MIMEText("للاستشارة الفورية: https://t.me/SaudiLegal_AI_bot", 'plain', 'utf-8')
                        msg['Subject'] = Header("استشارة قانونية عاجلة", 'utf-8')
                        msg['From'] = MY_EMAIL
                        msg['To'] = target
                        server.sendmail(MY_EMAIL, [target], msg.as_string())
                        sent += 1
                    except: continue
                server.quit()
                log(f"🏁 تم إرسال {sent} إيميل.")
                try: bot.send_message(CHAT_ID, f"✅ تم إرسال {sent} إيميل بنجاح.")
                except: pass
        except Exception as e:
            log(f"❌ فشل الدخول: {e}")
    else:
        log("❌ خطأ: لم يتم العثور على GMAIL_PASS في السيكرتس!")

    # 2. تشغيل البوت
    log("⚖️ البوت الآن مستعد للرد الفوري...")
    bot.infinity_polling(timeout=10, long_polling_timeout=5)

if __name__ == "__main__":
    start_alamid()
