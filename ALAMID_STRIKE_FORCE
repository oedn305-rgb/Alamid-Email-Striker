import os, smtplib, requests, time
from email.message import EmailMessage

# 1. جلب البيانات من السيكرتس وتحويلها لنصوص صافية
TOKEN = str(os.getenv("MS_APP_PASS", ""))
MY_EMAIL = str(os.getenv("GMAIL_USER", ""))
MY_PASS = str(os.getenv("GMAIL_PASS", ""))
CHAT_ID = "6381014522" 

def send_strike():
    print("🎯 [نظام العميد]: بدء استهداف الـ 1158 هدف...")
    try:
        # التأكد من وجود ملف الأهداف
        if not os.path.exists("emails.txt"):
            return "❌ خطأ: ملف emails.txt غير موجود في المستودع!"
            
        # قراءة الإيميلات مع تحديد التشفير لمنع خطأ الـ bytes
        with open("emails.txt", "r", encoding="utf-8") as f:
            targets = [line.strip() for line in f if "@" in line]
        
        if not targets:
            return "❌ خطأ: لم يتم العثور على أي إيميلات صالحة في الملف."

        # تجهيز سيرفر قوقل
        count = 0
        server = smtplib.SMTP_SSL('smtp.gmail.com', 465)
        server.login(MY_EMAIL, MY_PASS)
        
        # إرسال لأول 100 هدف (تقدر تزيدها لـ 500 في اليوم)
        for target in targets[:100]: 
            try:
                msg = EmailMessage()
                msg.set_content("⚖️ مكتب العميد للاستشارات القانونية 2026\nيسعدنا تواصلكم معنا لتقديم أفضل الخدمات.")
                msg['Subject'] = "تواصل قانوني عاجل"
                msg['From'] = MY_EMAIL
                msg['To'] = target
                
                server.send_message(msg)
                count += 1
                print(f"✅ [{count}] أرسلت بنجاح إلى: {target}")
            except Exception as e:
                print(f"⚠️ فشل في إرسال إيميل محدد ({target}): {e}")
            
        server.quit()
        return f"✅ تم إرسال {count} رسالة بنجاح من أصل 1158 هدف!"
        
    except Exception as e:
        return f"❌ فشل النظام بالكامل: {str(e)}"

def notify_telegram(message):
    # إرسال التقرير لتليجرام مشعل مباشرة
    url = f"https://api.telegram.org/bot{TOKEN}/sendMessage"
    payload = {"chat_id": CHAT_ID, "text": message}
    try:
        requests.post(url, json=payload, timeout=10)
        print("📲 تم إرسال التقرير النهائي لتليجرام بنجاح.")
    except:
        print("⚠️ لم يصل التقرير لتليجرام لكن الإيميلات أُرسلت.")

if __name__ == "__main__":
    # تشغيل المنظومة فوراً
    final_report = send_strike()
    print(final_report)
    
    # إرسال النتيجة لجوالك
    notify_telegram(f"🚀 [نظام العميد 2026]:\n{final_report}")
