def start_alamid():
    log("🚀 [نظام العميد]: بدء التشغيل النهائي...")
    
    # 1. إرسال الإيميلات أولاً
    try:
        log("📧 جاري محاولة الدخول للإيميل...")
        server = smtplib.SMTP_SSL('smtp.gmail.com', 465)
        # استخدام الباسورد المنظف
        server.login(MY_EMAIL, MY_PASS)
        log("✅ تم تسجيل الدخول بنجاح!")

        if os.path.exists("emails.txt"):
            with open("emails.txt", "r", encoding="utf-8") as f:
                targets = [l.strip() for l in f if "@" in l]
            
            for target in targets[:100]:
                try:
                    subject = "⚖️ استشارة قانونية عاجلة"
                    body = "للاستشارة الفورية: https://t.me/SaudiLegal_AI_bot"
                    msg = MIMEText(body, 'plain', 'utf-8')
                    msg['Subject'] = Header(subject, 'utf-8')
                    msg['From'] = MY_EMAIL
                    msg['To'] = target
                    server.sendmail(MY_EMAIL, [target], msg.as_string())
                except: continue
            server.quit()
            log("🏁 خلصنا الإيميلات بنجاح.")
    except Exception as e:
        log(f"❌ فشل الدخول للإيميل (تأكد من الـ 16 حرف): {e}")

    # 2. تشغيل البوت
    log("⚖️ البوت الآن مستعد للرد الفوري...")
    try:
        bot.send_message(CHAT_ID, "🚀 النظام متصل الآن.. جرب ترسل قضية.")
    except: pass
    
    bot.infinity_polling(timeout=10, long_polling_timeout=5)

if __name__ == "__main__":
