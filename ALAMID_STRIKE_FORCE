# --- الإعدادات المسحوبة من السيكرتس ---
TOKEN = str(os.getenv("MS_APP_PASS", "")).strip()
MY_EMAIL = "oedn305@gmail.com"
MY_PASS = str(os.getenv("GMAIL_PASS", "")).strip()
CHAT_ID = "6381014522"

bot = telebot.TeleBot(TOKEN)

def run_strike():
    print("🚀 [1/2] بدء مرحلة الهجوم: إرسال الإيميلات...")
    sent_count = 0
    
    try:
        # قراءة الأهداف
        with open("emails.txt", "r", encoding="utf-8") as f:
            targets = [line.strip() for line in f if "@" in line]
        
        if targets:
            server = smtplib.SMTP_SSL('smtp.gmail.com', 465)
            server.login(MY_EMAIL, MY_PASS)
            
            # إرسال 100 إيميل دفعة واحدة
            for target in targets[:100]:
                try:
                    subject = "⚖️ استشارة قانونية - مكتب المستشار السعودي"
                    body = f"للاستشارة الفورية والرد على قضاياكم، تواصلوا معنا عبر البوت الرسمي:\nhttps://t.me/SaudiLegal_AI_bot"
                    msg = f"From: {MY_EMAIL}\nTo: {target}\nSubject: {subject}\nContent-Type: text/plain; charset=utf-8\n\n{body}"
                    server.sendmail(MY_EMAIL, target, msg.encode('utf-8'))
                    sent_count += 1
                except: continue
            server.quit()
            print(f"✅ تم إرسال {sent_count} إيميل بنجاح.")
    except Exception as e:
        print(f"❌ فشل في مرحلة الإيميلات: {e}")

    # --- المرحلة الثانية: تشغيل رد البوت ---
    print("⚖️ [2/2] إيقاظ البوت لاستقبال القضايا...")
    bot.send_message(CHAT_ID, f"🏁 تم إرسال {sent_count} إيميل.\n\nالبوت الآن 'صاحي' لمدة 5 دقائق لاستقبال قضايا العملاء. ارسل قضيتك الآن!")

    @bot.message_handler(func=lambda message: True)
    def handle_messages(message):
        reply = "⚖️ تم استلام قضيتك بنجاح لدى مكتب المستشار القانوني السعودي. جاري مراجعة التفاصيل."
        bot.reply_to(message, reply)

    # تشغيل البوت لفترة محددة (عشان GitHub ما يعلقه)
    bot.polling(none_stop=True, interval=0, timeout=20)

if __name__ == "__main__":
    run_strike()
