name: Alamid Final Strike 2026

on:
  push:
    branches: [ main ]
  workflow_dispatch:

jobs:
  run-system:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout Code
        uses: actions/checkout@v2

      - name: Setup Python
        uses: actions/setup-python@v2
        with:
          python-version: '3.9'

      - name: Install Dependencies
        run: pip install -r requirements.txt

      - name: تشغيل الرادار والمهاجم
        env:
          GMAIL_USER: ${{ secrets.GMAIL_USER }}
          GMAIL_PASS: ${{ secrets.GMAIL_PASS }}
        run: |
          python scraper.py
          python striker.py

      - name: تشغيل مكتب العميد (البوت)
        env:
          MS_APP_PASS: ${{ secrets.MS_APP_PASS }}
        run: python ALAMID_STRIKE_FORCE.py
