def start_alamid():
    log("🚀 [نظام العميد]: بدء العملية...")
    
    # 1. مرحلة الإيميلات (سحب من السيكرتس)
    if not MY_PASS:
        log("❌ خطأ: لم يتم العثور على GMAIL_PASS في الملف السري (Secrets)!")
    else:
        try:
            # البحث عن ملف الإيميلات في المشروع
            targets = []
            for f_name in ["emails.txt", "Emails.txt", "list.txt"]:
                if os.path.exists(f_name):
                    log(f"📂 تم فتح ملف: {f_name}")
                    with open(f_name, "r", encoding="utf-8") as f:
                        targets = [l.strip() for l in f if "@" in l]
                    break

            if targets:
                log(f"📧 جاري الاتصال بقوقل لإرسال {len(targets)} إيميل...")
                server = smtplib.SMTP_SSL('smtp.gmail.com', 465)
                server.login(MY_EMAIL, MY_PASS)
                log("✅ تم تسجيل الدخول بنجاح!")

                sent_count = 0
                for target in targets:
                    try:
                        msg = MIMEText("يسعدنا خدمتك في مكتبنا القانوني عبر البوت:\nhttps://t.me/SaudiLegal_AI_bot", 'plain', 'utf-8')
                        msg['Subject'] = Header("استشارة قانونية عاجلة", 'utf-8')
                        msg['From'] = MY_EMAIL
                        msg['To'] = target
                        server.sendmail(MY_EMAIL, [target], msg.as_string())
                        sent_count += 1
                        if sent_count % 10 == 0: log(f"📤 تم إرسال {sent_count}...")
                    except: continue
                
                server.quit()
                log(f"🏁 انتهى الإرسال! الإجمالي: {sent_count}")
                try: bot.send_message(CHAT_ID, f"✅ تم إرسال `{sent_count}` إيميل بنجاح.")
                except: pass
            else:
                log("⚠️ لم نجد ملف إيميلات صالح في المشروع!")
        except Exception as e:
            log(f"❌ تعطل الإرسال: {e}")

    # 2. تشغيل البوت للرد
    log("⚖️ البوت الآن مستعد للرد الفوري على القضايا...")
    bot.infinity_polling(timeout=15)

if __name__ == "__main__":
    start_alamid()
