import os, smtplib, requests

# --- الإعدادات (تأكد من صحتها في السيكرتس) ---
TOKEN = str(os.getenv("MS_APP_PASS", "")).strip()  # توكن تليجرام
MY_EMAIL = "oedn305@gmail.com"
MY_PASS = str(os.getenv("GMAIL_PASS", "")).strip() # كود الـ 16 حرف
CHAT_ID = "6381014522" 

def send_strike():
    print(f"⚖️ [نظام العميد 2026]: بدء إرسال المحتوى المعتمد...")
    
    try:
        with open("emails.txt", "r", encoding="utf-8") as f:
            targets = [line.strip() for line in f if "@" in line]
        
        server = smtplib.SMTP_SSL('smtp.gmail.com', 465)
        server.login(MY_EMAIL, MY_PASS)
        
        count = 0
        for target in targets[:100]: 
            try:
                # --- النص الرسمي اللي طلبته (تقدر تعدله هنا) ---
                subject = "⚖️ مكتب العميد للاستشارات القانونية - تواصل عاجل"
                body = f"""
مرحباً بك،

يسعدنا في "مكتب العميد للاستشارات القانونية 2026" التواصل معكم بناءً على طلبكم/اهتماماتكم السابقة. 
نحن هنا لنقدم لكم الدعم القانوني الاحترافي الذي يستحقه عملاؤنا.

للتواصل المباشر أو الاستفسار:
- الرد على هذا الإيميل مباشرة.
- التواصل عبر الواتساب المعتمد للمكتب.

نعتز بثقتكم،
إدارة مكتب العميد 2026.
                """
                
                # بناء الرسالة مع دعم اللغة العربية (UTF-8)
                msg = f"From: {MY_EMAIL}\nTo: {target}\nSubject: {subject}\nContent-Type: text/plain; charset=utf-8\n\n{body}"
                
                server.sendmail(MY_EMAIL, target, msg.encode('utf-8'))
                count += 1
                print(f"✅ تم الإرسال إلى: {target}")
            except: continue
            
        server.quit()
        return count
    except Exception as e:
        print(f"❌ خطأ: {e}")
        return 0

def notify_bot(count):
    # إرسال تقرير ذكي لبوت تليجرام
    url = f"https://api.telegram.org/bot{TOKEN}/sendMessage"
    text = f"⚖️ *تقرير نظام العميد 2026*\n\n✅ تم بنجاح استهداف: `{count}` عميل.\n🎯 الأهداف المتبقية: `{1158 - count}`\n🚀 النظام جاهز للدفعة القادمة."
    payload = {
        "chat_id": CHAT_ID, 
        "text": text, 
        "parse_mode": "Markdown"
    }
    requests.post(url, json=payload)

if __name__ == "__main__":
    total_sent = send_strike()
    if total_sent > 0:
        notify_bot(total_sent)
        print(f"🏁 المهمة تمت! أرسلنا لـ {total_sent} عميل.")
